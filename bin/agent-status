#!/usr/bin/env bash
# Usage: agent-status <working|waiting|done|clear>

set -u

command -v tmux >/dev/null 2>&1 || exit 0

target_pane="${TMUX_PANE:-}"

case "${1:-clear}" in
  working) icon="🤖" ;;
  waiting) icon="💬" ;;
  done) icon="✅" ;;
  clear) icon="" ;;
  *) icon="$1" ;;
esac

if [ -n "$target_pane" ]; then
  if [ -n "$icon" ]; then
    tmux set-option -p -t "$target_pane" @agent_status "$icon" 2>/dev/null
  else
    tmux set-option -p -t "$target_pane" -u @agent_status 2>/dev/null
  fi
fi

panes=$(tmux list-panes -F '#{pane_id}' 2>/dev/null) || exit 0

has_waiting=false
has_working=false
has_done=false

for pane_id in $panes; do
  status=$(tmux show-options -pqv -t "$pane_id" @agent_status 2>/dev/null)
  case "$status" in
    "💬") has_waiting=true ;;
    "🤖") has_working=true ;;
    "✅") has_done=true ;;
  esac
done

if $has_waiting; then
  tmux set-option -w @agent_status "💬" 2>/dev/null
elif $has_working; then
  tmux set-option -w @agent_status "🤖" 2>/dev/null
elif $has_done; then
  tmux set-option -w @agent_status "✅" 2>/dev/null
else
  tmux set-option -w -u @agent_status 2>/dev/null
fi

exit 0
